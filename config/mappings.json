{
  "appProfiles": {
    "com.mitchellh.ghostty": "ghostty"
  },
  "alwaysOn": {
    "analog": {
      "leftStickVerticalScroll": {
        "enabled": true,
        "deadzone": 0.20,
        "intervalMs": 50,
        "minLinesPerTick": 1,
        "maxLinesPerTick": 8,
        "responseExponent": 2.6,
        "invert": false
      }
    },
    "mappings": {
      "rightTrigger": {
        "action": {
          "type": "holdKeystroke",
          "keyCode": 111,
          "modifiers": [],
          "description": "Hold to mimic F12"
        }
      },
      "leftTrigger": {
        "action": {
          "type": "holdKeystroke",
          "keyCode": 55,
          "modifiers": [],
          "description": "Hold Command modifier"
        }
      },
      "x": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [],
          "description": "Send Tab (L2 + X behaves like Cmd+Tab)"
        }
      },
      "dpadUp": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 126,
          "modifiers": [],
          "description": "Send Up Arrow"
        }
      },
      "dpadDown": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 125,
          "modifiers": [],
          "description": "Send Down Arrow"
        }
      },
      "dpadLeft": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 123,
          "modifiers": [],
          "description": "Send Left Arrow"
        }
      },
      "dpadRight": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 124,
          "modifiers": [],
          "description": "Send Right Arrow"
        }
      }
    }
  },
  "profiles": {
    "ghostty": {
      "enabled": true,
      "analog": {
        "rightStickVerticalActions": {
          "enabled": true,
          "deadzone": 0.66,
          "edgeTrigger": true,
          "upAction": {
            "type": "text",
            "text": "/model",
            "delayMs": 80,
            "pressEnter": true,
            "description": "Open /model popup from right stick up"
          },
          "downAction": {
            "type": "text",
            "text": "/fast",
            "delayMs": 80,
            "pressEnter": true,
            "description": "Open /fast from right stick down"
          }
        },
        "rightStickHorizontalActions": {
          "enabled": true,
          "deadzone": 0.62,
          "edgeTrigger": true,
          "leftAction": {
            "type": "keystroke",
            "keyCode": 44,
            "modifiers": [],
            "description": "Send slash (/)"
          },
          "rightAction": {
            "type": "keystroke",
            "keyCode": 21,
            "modifiers": [
              "shift"
            ],
            "description": "Send dollar sign ($)"
          }
        }
      },
      "mappings": {
        "options": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "close_surface",
            "description": "Close focused split surface via Ghostty native action"
          }
        },
        "share": {
          "debounceMs": 500,
          "edgeTrigger": true,
          "action": {
            "type": "shell",
            "command": "$HOME/.agents/codex/scripts/open-ghostty-codex-picker-tab.sh",
            "description": "Capture button: open a new Ghostty picker tab via the shared Codex helper"
          }
        },
        "rightThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_split:right",
            "description": "Split right via Ghostty native action"
          }
        },
        "leftThumbstickButton": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "shell",
            "command": "$HOME/.agents/codex/scripts/open-ghostty-codex-picker-split.sh --direction right",
            "description": "Split right and open the Codex repo picker in the new split"
          }
        },
        "a": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 36,
            "modifiers": [],
            "description": "Send Enter"
          }
        },
        "b": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 53,
            "modifiers": [],
            "description": "Send Escape"
          }
        },
        "y": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 51,
            "modifiers": [],
            "description": "Send Backspace"
          }
        },
        "leftShoulder": {
          "debounceMs": 200,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:next",
            "description": "Cycle splits within current tab via Ghostty native action"
          }
        },
        "rightShoulder": {
          "debounceMs": 200,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "next_tab",
            "description": "Cycle tabs via Ghostty native action"
          }
        }
      }
    }
  },
  "safety": {
    "dryRun": true,
    "emergencyToggleButton": null
  }
}
