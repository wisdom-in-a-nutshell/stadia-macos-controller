{
  "appProfiles": {
    "com.mitchellh.ghostty": "ghostty"
  },
  "alwaysOn": {
    "analog": {
      "leftStickVerticalScroll": {
        "enabled": true,
        "deadzone": 0.20,
        "intervalMs": 50,
        "minLinesPerTick": 1,
        "maxLinesPerTick": 8,
        "responseExponent": 2.6,
        "invert": false
      }
    },
    "mappings": {
      "rightTrigger": {
        "action": {
          "type": "holdKeystroke",
          "keyCode": 111,
          "modifiers": [],
          "description": "Hold to mimic F12"
        }
      },
      "leftTrigger": {
        "action": {
          "type": "holdKeystroke",
          "keyCode": 55,
          "modifiers": [],
          "description": "Hold Command modifier"
        }
      },
      "x": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [],
          "description": "Send Tab (L2 + X behaves like Cmd+Tab)"
        }
      }
    }
  },
  "profiles": {
    "ghostty": {
      "enabled": true,
      "analog": {
        "rightStickHorizontalActions": {
          "enabled": false,
          "deadzone": 0.62,
          "edgeTrigger": true,
          "leftAction": {
            "type": "keystroke",
            "keyCode": 123,
            "modifiers": [
              "control"
            ],
            "description": "Move one macOS workspace left (Control+Left Arrow)"
          },
          "rightAction": {
            "type": "keystroke",
            "keyCode": 124,
            "modifiers": [
              "control"
            ],
            "description": "Move one macOS workspace right (Control+Right Arrow)"
          }
        }
      },
      "mappings": {
        "options": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 13,
            "modifiers": [
              "command"
            ],
            "description": "Close focused split surface (Ghostty close_surface via Cmd+W)"
          }
        },
        "menu": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "text",
            "text": "/model",
            "delayMs": 80,
            "pressEnter": true,
            "description": "Open /model popup"
          }
        },
        "share": {
          "debounceMs": 500,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 17,
            "modifiers": [
              "command"
            ],
            "description": "Capture button: open new tab (Ghostty auto-runs codex)"
          }
        },
        "leftThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 2,
            "modifiers": [
              "command",
              "shift"
            ],
            "description": "Split down (Cmd+Shift+D)"
          }
        },
        "rightThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 2,
            "modifiers": [
              "command"
            ],
            "description": "Split right (Cmd+D)"
          }
        },
        "a": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 36,
            "modifiers": [],
            "description": "Send Enter"
          }
        },
        "b": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 53,
            "modifiers": [],
            "description": "Send Escape"
          }
        },
        "y": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 5,
            "modifiers": [
              "command",
              "shift"
            ],
            "description": "Send Cmd+Shift+G"
          }
        },
        "leftShoulder": {
          "debounceMs": 200,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 30,
            "modifiers": [
              "command"
            ],
            "description": "Cycle splits within current tab (Ghostty goto_split:next via Cmd+])"
          }
        },
        "rightShoulder": {
          "debounceMs": 200,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 30,
            "modifiers": [
              "command",
              "shift"
            ],
            "description": "Cycle tabs (next tab, Cmd+Shift+])"
          }
        },
        "dpadUp": {
          "debounceMs": 140,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 126,
            "modifiers": [],
            "description": "Model picker move up"
          }
        },
        "dpadDown": {
          "debounceMs": 140,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 125,
            "modifiers": [],
            "description": "Model picker move down"
          }
        },
        "dpadLeft": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 44,
            "modifiers": [],
            "description": "Send slash"
          }
        },
        "dpadRight": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "text",
            "text": "$",
            "description": "Send dollar sign"
          }
        }
      }
    }
  },
  "safety": {
    "dryRun": true,
    "emergencyToggleButton": null
  }
}
