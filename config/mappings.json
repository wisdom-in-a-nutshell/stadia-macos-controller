{
  "appProfiles": {
    "com.mitchellh.ghostty": "ghostty"
  },
  "alwaysOn": {
    "analog": {
      "leftStickVerticalScroll": {
        "enabled": true,
        "deadzone": 0.20,
        "intervalMs": 50,
        "minLinesPerTick": 1,
        "maxLinesPerTick": 8,
        "responseExponent": 2.6,
        "invert": false
      }
    },
    "mappings": {
      "rightTrigger": {
        "action": {
          "type": "holdKeystroke",
          "keyCode": 111,
          "modifiers": [],
          "description": "Hold to mimic F12"
        }
      },
      "leftTrigger": {
        "action": {
          "type": "holdKeystroke",
          "keyCode": 55,
          "modifiers": [],
          "description": "Hold Command modifier"
        }
      },
      "x": {
        "debounceMs": 180,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 48,
          "modifiers": [],
          "description": "Send Tab (L2 + X behaves like Cmd+Tab)"
        }
      },
      "dpadUp": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 126,
          "modifiers": [],
          "description": "Send Up Arrow"
        }
      },
      "dpadDown": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 125,
          "modifiers": [],
          "description": "Send Down Arrow"
        }
      },
      "dpadLeft": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 123,
          "modifiers": [],
          "description": "Send Left Arrow"
        }
      },
      "dpadRight": {
        "debounceMs": 140,
        "edgeTrigger": true,
        "action": {
          "type": "keystroke",
          "keyCode": 124,
          "modifiers": [],
          "description": "Send Right Arrow"
        }
      }
    }
  },
  "profiles": {
    "ghostty": {
      "enabled": true,
      "analog": {
        "rightStickHorizontalActions": {
          "enabled": true,
          "deadzone": 0.62,
          "edgeTrigger": true,
          "leftAction": {
            "type": "keystroke",
            "keyCode": 44,
            "modifiers": [],
            "description": "Send slash (/)"
          },
          "rightAction": {
            "type": "keystroke",
            "keyCode": 21,
            "modifiers": [
              "shift"
            ],
            "description": "Send dollar sign ($)"
          }
        }
      },
      "mappings": {
        "options": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "close_surface",
            "description": "Close focused split surface via Ghostty native action"
          }
        },
        "menu": {
          "debounceMs": 220,
          "edgeTrigger": true,
          "action": {
            "type": "text",
            "text": "/model",
            "delayMs": 80,
            "pressEnter": true,
            "description": "Open /model popup"
          }
        },
        "share": {
          "debounceMs": 500,
          "edgeTrigger": true,
          "action": {
            "type": "applescript",
            "script": "tell application \"Ghostty\"\n  set launchConfig to new surface configuration\n  set environment variables of launchConfig to {\"CODEX_DISABLE_AUTOSTART=1\"}\n  set command of launchConfig to \"/bin/zsh -l\"\n  set initial input of launchConfig to \"codex_jump\\n\"\n  if (count windows) = 0 then\n    new window with configuration launchConfig\n  else\n    new tab in front window with configuration launchConfig\n  end if\nend tell",
            "description": "Capture button: open a new Ghostty tab and immediately launch the Codex repo picker"
          }
        },
        "rightThumbstickButton": {
          "debounceMs": 180,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "new_split:right",
            "description": "Split right via Ghostty native action"
          }
        },
        "a": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 36,
            "modifiers": [],
            "description": "Send Enter"
          }
        },
        "b": {
          "debounceMs": 120,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 53,
            "modifiers": [],
            "description": "Send Escape"
          }
        },
        "y": {
          "debounceMs": 160,
          "edgeTrigger": true,
          "action": {
            "type": "keystroke",
            "keyCode": 5,
            "modifiers": [
              "command",
              "shift"
            ],
            "description": "Open the Codex jump picker in the current Ghostty terminal"
          }
        },
        "leftShoulder": {
          "debounceMs": 200,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "goto_split:next",
            "description": "Cycle splits within current tab via Ghostty native action"
          }
        },
        "rightShoulder": {
          "debounceMs": 200,
          "edgeTrigger": true,
          "action": {
            "type": "ghosttyAction",
            "ghosttyAction": "next_tab",
            "description": "Cycle tabs via Ghostty native action"
          }
        }
      }
    }
  },
  "safety": {
    "dryRun": true,
    "emergencyToggleButton": null
  }
}
